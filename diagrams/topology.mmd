graph TB
    subgraph Fabric["AWS Cloud WAN — Core Network"]
        CN["Core Network<br/>segments: prod, dev<br/>tag-based attachment policy"]
    end

    subgraph East["us-east-1 — segment: prod"]
        VPCE["VPC-East<br/>10.10.0.0/16"]
        E1["EC2-East<br/>t3.nano<br/>10.10.1.x"]
        VPNA["S2S VPN attachment<br/>tag Segment=prod<br/>2 tunnels, static routes"]
        VPCE --- E1
    end

    subgraph West["us-west-2 — segment: dev"]
        VPCW["VPC-West<br/>10.20.0.0/16"]
        W1["EC2-West<br/>t3.nano<br/>10.20.1.x"]
        VPCW --- W1
    end

    subgraph Home["on-prem — laptop NAT (WAN 24.42.204.221)"]
        NAT["home router<br/>outbound NAT only<br/>(no port-forward needed)"]
        subgraph Clab["containerlab — EVPN fabric"]
            CPE["cpe-east<br/>alpine + strongswan<br/>mgmt 172.31.10.103<br/>tenant 192.168.100.50/24<br/>auto=start (initiator)"]
            L1["leaf1<br/>SVI Vlan100<br/>TENANT-A VRF"]
            SP["spine1 / spine2<br/>EVPN underlay"]
            L2["leaf2"]
            H1["h1<br/>192.168.100.101"]
            CPE -- "eth1<br/>access VLAN 100" --> L1
            L1 --- SP
            SP --- L2
            L2 --- H1
        end
        NAT --- CPE
    end

    VPCE -- "VPC attachment<br/>tag Segment=prod" --> CN
    VPCW -- "VPC attachment<br/>tag Segment=dev" --> CN
    VPNA -- "VPN attachment<br/>tag Segment=prod" --> CN
    CPE == "IPsec IKEv2 + ESP, NAT-T<br/>initiated outbound by cpe-east<br/>advertises 192.168.100.0/24" ==> VPNA

